# ====================================================================
# AD User Management Tool — environment variables
# Copy to .env and fill in. Never commit a populated .env.
# ====================================================================

# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=info

# --- API ---
API_HOST=0.0.0.0
API_PORT=3000
# Origin allowed by CORS (frontend dev server). Comma-separated for multiple.
API_CORS_ORIGIN=http://localhost:5173
# Secret used to sign session cookies. >=32 chars. Rotate via env.
SESSION_COOKIE_SECRET=change-me-to-a-long-random-string-at-least-32-chars
SESSION_IDLE_TIMEOUT_MINUTES=60
SESSION_ABSOLUTE_TIMEOUT_HOURS=12
STEP_UP_TTL_MINUTES=60

# AES-256 key for encrypting service-account credentials at rest.
# Base64-encoded 32 bytes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=change-me-to-a-base64-encoded-32-byte-key

# --- Database ---
# DATABASE_URL must always be set. POSTGRES_* are only required when using
# the bundled Postgres container (docker-compose.yml). Generate the password
# with `openssl rand -hex 24` and use the same value here and in DATABASE_URL.
DATABASE_URL=postgres://openaduc:change-me-to-a-strong-random-password@localhost:5432/openaduc
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Embedded Postgres only (leave blank when DATABASE_URL points at an external DB).
POSTGRES_USER=openaduc
POSTGRES_PASSWORD=change-me-to-a-strong-random-password
POSTGRES_DB=openaduc

# --- Worker ---
WORKER_CONCURRENCY=5

# --- Active Directory (OPTIONAL — configure via setup wizard instead) ---
# When all AD_* vars are set AND no directory_providers row exists in the DB,
# the api will seed a row from these on first call. Once a row exists, the
# DB wins; env values are ignored. The setup wizard at /setup is the
# recommended path for new deployments.
# AD_LDAP_URLS=ldaps://dc1.example.com:636
# AD_DOMAIN=example.com
# AD_BASE_DN=DC=example,DC=com
# AD_SERVICE_ACCOUNT_UPN=openaduc-sync@example.com
# AD_SERVICE_ACCOUNT_PASSWORD=change-me
# TLS validation. Set to "0" only for local dev with self-signed Samba.
AD_TLS_REJECT_UNAUTHORIZED=0
AD_TLS_CA_PATH=
# Timeout in milliseconds for individual LDAP operations.
AD_OPERATION_TIMEOUT_MS=15000

# --- Authorization ---
# Bootstrap: AD group DN whose members get full admin capability before
# in-app role config exists. Optional; recovery account works without it.
# BOOTSTRAP_ADMIN_GROUP_DN=CN=OpenADUC Admins,CN=Users,DC=example,DC=com

# --- Frontend (build-time) ---
VITE_API_BASE_URL=/api
